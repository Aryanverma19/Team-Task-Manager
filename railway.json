{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "buildPack": "nixpacks",
    "nodeVersion": "22",
    "installCommand": "npm_config_production=false npm install --workspaces",
    "buildCommand": "npm run build --workspace=client && npx prisma generate --schema=server/prisma/schema.prisma",
    "startCommand": "npm run start --workspace=server"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
