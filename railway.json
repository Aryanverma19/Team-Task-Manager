{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "buildPack": "nixpacks",
    "nodeVersion": "22",
    "installCommand": "npm install --workspace=server",
    "buildCommand": "echo 'No build needed for server'",
    "startCommand": "npm run start --workspace=server"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
