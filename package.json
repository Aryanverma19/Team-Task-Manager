{
  "name": "team-task-manager",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently \"npm --workspace=server run dev\" \"npm --workspace=client run dev\"",
    "start": "npm --workspace=server run start",
    "install-all": "npm install --workspaces"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
